# =========================================================
#  numa_server / agent — 環境変数テンプレート
#  cp .env.example .env してから値を埋める (要 chmod 600 .env)
# =========================================================

# --- Ollama (ollama_net 内部接続) ---
OLLAMA_BASE_URL=http://ollama:11434
AGENT_MODEL=qwen3.6:35b-a3b-q4_K_M
# keep_alive はモデル名から自動判定される(未設定で可・汎用設計):
#   OLLAMA_NO_WARM_MODELS に一致するモデル(既定 qwen3.6 等のSSM)→ "0"(毎回再ロードで
#   warm slot クラッシュ回避)、それ以外(gemma4 等)→ warm化して高速。
# 下の2つは通常いじらなくてよい。明示したいときだけコメント解除する。
#OLLAMA_KEEP_ALIVE=5m        # 明示するとモデル別自動判定を無効化し全モデルでこの値に固定
#OLLAMA_NO_WARM_MODELS=qwen3.6  # warm化でクラッシュするモデル名パターン(部分一致・カンマ区切り)

# --- Discord (必須・Phase 0) ---
# Discord Developer Portal で作成したボットトークン
DISCORD_BOT_TOKEN=
# 通知/承認を投稿するチャンネルのID (開発者モードで右クリック→IDをコピー)
DISCORD_CHANNEL_ID=
# 司書: このチャンネルでの発話を解釈し方針(directive)を会話でCRUDする(段階B)。
# 要 Discord Developer Portal の「Message Content Intent」有効化。
LIBRARIAN_ENABLED=true
# 短期会話セッション: この分数 無応答だと会話の文脈をリセット(プロセス内のみ)
SESSION_IDLE_MIN=5
SESSION_MAX_MESSAGES=12      # セッションで保持する発話数(user+assistant 合算)

# --- 動作設定 ---
# クロールの実行タイミング。CRAWL_HOURS を設定すると「時刻指定(cron)」になり
# 各時刻(時)の CRAWL_MINUTE 分に実行する。空なら CRAWL_INTERVAL_MIN の固定間隔(後方互換)。
CRAWL_HOURS=1,5,9,12,15,18,21  # 1日7回(夜間1/5時+日中9/12/15/18/21時)。空ならインターバル方式
CRAWL_MINUTE=0               # 各時刻の何分に実行するか (cron 方式時のみ)
CRAWL_INTERVAL_MIN=30        # 定期クロール間隔(分) — CRAWL_HOURS 未設定時のみ使用
MAX_PROPOSALS_PER_RUN=10     # 1回のクロールで出す提案の上限
RUN_ON_START=true            # 起動直後に1回クロールを実行 (動作確認用)
REQUIRE_APPROVAL=false       # タスク追加に Discord 承認を挟むか (既定 false=直接Notionへ挿入)

# --- 実行履歴 (#64: いつ何を見て何をしたかの記録) ---
# クロール/返信案サイクル毎に「何を見て何をした」を data/runs.jsonl に記録(常時)し、
# Discord にも簡潔なサマリを出す(提案なし/エラーも含め毎回)。自動起動の活動を可視化する。
RUN_SUMMARY_ENABLED=true     # 毎回のサマリ通知を出すか (記録は本設定に関わらず常に残る)
# サマリの送信先チャンネルID。空/0 なら通常の通知チャンネル(DISCORD_CHANNEL_ID)に送る。
# 提案/追加など承認ボタン付き通知は従来チャンネルのまま、サマリだけ別チャンネルに分けられる。
RUN_SUMMARY_CHANNEL_ID=
RUNS_HISTORY_LIMIT=15        # 司書に『最近何やった?』と聞いた時に表示する直近の実行数

# --- マネージャ・オーケストレータ (#62 段階2) ---
# true: 1クロールを「計画→逐次実行→統合」に再構成しコンテキスト分割。false: 従来の一括reconcile。
ORCHESTRATOR_ENABLED=false
ORCHESTRATOR_MAX_SUBTASKS=20  # マネージャが書き出すサブタスクの上限
ORCHESTRATOR_BATCH_SIZE=3     # inspect_email 1呼び出しで精査するメール件数(満溢回避)

# --- Web リサーチ (#62 段階3, SearXNG 自ホスト) ---
# true で web_research サブタスクが実検索(SearXNG)→要約。要 searxng コンテナ起動。
WEB_RESEARCH_ENABLED=false
SEARXNG_URL=http://searxng:8080  # 内部専用 SearXNG (ollama_net)
WEB_SEARCH_MAX_RESULTS=5         # 1検索で採用する結果数
WEB_FETCH_MAX_CHARS=3000         # ページ取得時に要約へ渡す本文の上限

# --- Google (Phase 1, 読み取り専用スコープのみ) ---
# OAuthクライアントJSON と 初回認可で生成されるトークンの置き場 (./data にマウントされる)
GOOGLE_OAUTH_CLIENT_JSON=/app/data/google_client.json
GOOGLE_TOKEN_JSON=/app/data/google_token.json
# 取得対象メールの Gmail 検索クエリ
GMAIL_QUERY=is:unread (is:important OR is:starred)
GMAIL_MAX_RESULTS=15
GMAIL_BODY_MAX_CHARS=4000     # 返信生成に渡すメール本文の上限
# Calendar で先読みする日数
CALENDAR_LOOKAHEAD_DAYS=14

# --- メール返信案 (Phase 2a, 読み取り専用) ---
# 返信が必要なメールの返信案を生成し Discord に提示するだけ (Gmailへの書込なし)。
# 追加スコープ・再認可は不要。
DRAFT_ENABLED=false
DRAFT_MAX_PER_RUN=5           # 1回で生成する返信案(出力)の上限
DRAFT_MAX_CANDIDATES=4       # 1回にLLMへ渡す候補メール(入力)の上限。多いとnum_ctx超過で落ちる
# 日程提案用の空き時間計算 (カレンダーから決定論的に算出)
AVAIL_DAYS=14                # 何日先まで空き枠を探すか
AVAIL_DAY_START=9            # 営業時間の開始(時)
AVAIL_DAY_END=21             # 営業時間の終了(時)
AVAIL_WEEKDAYS_ONLY=true     # 平日のみ提案
AVAIL_MIN_MINUTES=60         # 空き枠とみなす最小の連続時間(分)
AVAIL_MAX_SLOTS=12           # LLMに渡す空き枠の最大数

# --- エージェント・メモリ層 (docs/agent-memory.md) ---
# directive層: 全動作が常時参照するルール(data/directives.json・人間可読・常時ON)。
#   ゴミタスク抑制等。投入: python /app/scripts/seed_directives.py / 一覧: --list
MEMORY_DIRECTIVE_BUDGET=15   # 常時注入する方針の最大件数(global+domain合算)
# example層(RAG・任意・依存が重いので既定 false): 過去の返信案等を Chroma(data/chroma)に
#   蓄積し類似時に文体の参考として渡す。要 nomic-embed-text の pull:
#   docker exec -it ollama ollama pull nomic-embed-text
MEMORY_ENABLED=false
EMBED_MODEL=nomic-embed-text
MEMORY_TOP_K=3               # 1クエリあたり想起する類似事例の数
MEMORY_MAX_DISTANCE=0.6      # cosine距離の上限(超えたら無関係として除外)

# --- Notion (Phase 1) ---
NOTION_API_TOKEN=
NOTION_TASKS_DB_ID=
# 締切を書き込む date プロパティ名 (DBに無ければスキップ)
NOTION_DUE_PROP=Due
# 由来ID/リンクを書き込む rich_text プロパティ名 (任意・重複防止に使う。空ならタイトルのみで重複判定)
NOTION_SOURCE_PROP=
# 新規タスクのデフォルトのステータス (status/select型プロパティ。DBに無ければスキップ)
NOTION_STATUS_PROP=Status
NOTION_DEFAULT_STATUS=未着手
# 挿入者を示すタグ (multi_select/select型プロパティ。DBに無ければスキップ)
NOTION_TAG_PROP=Tags
NOTION_AGENT_TAG=Agent

# --- Moodle (Phase 1.5 — MVPでは未使用) ---
MOODLE_BASE_URL=
MOODLE_WS_TOKEN=
