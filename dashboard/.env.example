# Dashboard login password (plain text — protect this file with chmod 600)
DASHBOARD_PASSWORD=your_secure_password_here

# JWT signing secret — generate with: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here

# Optional: comma-separated IP CIDR allowlist for login (leave empty to allow all LAN)
# Example: ALLOWED_IPS=192.168.1.0/24,10.0.0.1
ALLOWED_IPS=
