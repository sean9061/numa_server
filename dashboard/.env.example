# Dashboard login password (plain text — protect this file with chmod 600)
DASHBOARD_PASSWORD=your_secure_password_here

# JWT signing secret — generate with: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here

# Optional: comma-separated IP CIDR allowlist for login (leave empty to allow all LAN)
# Example: ALLOWED_IPS=192.168.1.0/24,10.0.0.1
ALLOWED_IPS=

# Optional: NPM log file name fragment for portfolio traffic filtering
# Set to a substring of the NPM proxy host log filename (e.g. "proxy-host-2")
# Leave empty to count all NPM access logs as portfolio traffic
PORTFOLIO_LOG=

# HOME panel — SwitchBot Cloud API (v1.1). Get token/secret in the SwitchBot app:
#   Profile → Preferences → tap "App Version" 10x → Developer Options → Get Token / Secret Key
# Leave empty to disable the HOME panel.
SWITCHBOT_TOKEN=
SWITCHBOT_SECRET=
# Poll interval (seconds). Cloud budget is 10,000 req/day; cost = devices * 86400 / interval.
HOME_POLL_SECONDS=90
